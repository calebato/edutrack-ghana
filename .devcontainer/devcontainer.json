  "name": "EduTrack Ghana",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/var/www/html",
  "overrideCommand": false,
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "EduTrack Ghana",
      "onAutoForward": "openBrowser"
    }
  }
}
